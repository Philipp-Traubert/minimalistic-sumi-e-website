# ──────────────────────────────────────────────────────────────
# Google Places API
# ──────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com/
# 2. Create a project (e.g. "loslasszen-reviews")
# 3. Enable "Places API"
# 4. Create an API key → restrict it to "Places API" + your domain
# 5. Paste the key below

GOOGLE_PLACE_ID=ChIJdfbWSeAivGXM__ju-OLk3A
GOOGLE_BUSINESS_NAME=loslasszen Körperarbeit
GOOGLE_PLACES_API_KEY=

# ──────────────────────────────────────────────────────────────
# Facebook Graph API  (optional – add when you have a FB page)
# ──────────────────────────────────────────────────────────────
# 1. Go to https://developers.facebook.com/apps
# 2. Create an app (type: Business)
# 3. Add "pages_read_engagement" permission
# 4. Generate a long-lived Page Access Token
# 5. Get your numeric Page ID from your page's About section

FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
